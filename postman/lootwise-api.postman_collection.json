{
  "info": {
    "_postman_id": "7f1d2d9f-cf6c-4fcf-932f-0ab2e8d40f10",
    "name": "Lootwise API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for local Lootwise deal API testing."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "limit",
      "value": "20"
    },
    {
      "key": "appId",
      "value": "570"
    }
  ],
  "item": [
    {
      "name": "Deals",
      "item": [
        {
          "name": "Get Top Deals",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/deals?limit={{limit}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "deals"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "{{limit}}"
                }
              ]
            },
            "description": "Returns discounted deals sorted by discountPercent desc and totalReviews desc."
          },
          "response": []
        },
        {
          "name": "Get Deal Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/deals/{{appId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "deals",
                "{{appId}}"
              ]
            },
            "description": "Returns deal detail for the given Steam appId."
          },
          "response": []
        },
        {
          "name": "Get Top Deals - Invalid Limit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/deals?limit=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "deals"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "0"
                }
              ]
            },
            "description": "Validation example for limit."
          },
          "response": []
        },
        {
          "name": "Get Deal Detail - Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 404\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/deals/999999999",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "deals",
                "999999999"
              ]
            },
            "description": "Not found example."
          },
          "response": []
        }
      ]
    }
  ]
}
